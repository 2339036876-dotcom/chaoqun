{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/merchant/(.*)",
      "dest": "/merchant-web/dist/$1"
    },
    {
      "src": "/merchant",
      "dest": "/merchant-web/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/user-web/dist/$1"
    },
    {
      "src": "/",
      "dest": "/user-web/dist/index.html"
    }
  ]
}
