{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/merchant/(.*)",
      "dest": "/merchant-web/dist/$1",
      "headers": {
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/user-web/dist/$1",
      "headers": {
        "Cache-Control": "no-cache"
      }
    }
  ]
}
