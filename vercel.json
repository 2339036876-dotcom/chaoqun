{
  "buildCommand": "cd user-web && npm install && npm run build && cd ../merchant-web && npm install && npm run build",
  "outputDirectory": ".",
  "routes": [
    {
      "src": "/user/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot))$",
      "dest": "/user-web/dist/$1"
    },
    {
      "src": "/user/(.*)",
      "dest": "/user-web/dist/index.html"
    },
    {
      "src": "/merchant/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot))$",
      "dest": "/merchant-web/dist/$1"
    },
    {
      "src": "/merchant/(.*)",
      "dest": "/merchant-web/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
